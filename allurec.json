{
  "name": "Restful Booker Test Report",
  "output": "./allure-report",
  "historyPath": "./history.jsonl",
  "historyLimit":10,
  "qualityGate": {
    "rules": [
      {
        "maxFailures": 3,
        "fastFail": true
      }
    ]
  },
  "plugins": {
    "awesome": {
      "options": {
        "reportName": "Restful Booker Awesome Test Report",
        "singleFile": false,
        "reportLanguage": "en",
        "open": false,
                "publish": true
      }
    },
    "allure2": {
      "options": {
        "reportName": "Restful Booker Allure2 Test Report",
        "singleFile": false,
        "reportLanguage": "en"
      }
    },
    "classic": {
      "options": {
        "reportName": "Restful Booker Classic Test Report",
        "singleFile": false,
        "reportLanguage": "en"
      }
    },
    "dashboard": {
      "options": {
        "singleFile": false,
        "reportName": "Restful Booker Dashboard Test Report",
        "reportLanguage": "en"
      }
    },
    "csv": {
      "options": {
        "fileName": "allure-report.csv"
      }
    },
    "log": {
      "options": {
        "groupBy": "none"
      }
    }
  },
  "variables": {
    
  }
}
